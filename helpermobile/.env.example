# Ortam değişkenleri şablonu.
# Bu dosyayı `.env` olarak kopyalayıp değerleri kendi anahtarlarınızla doldurun:
#   cp .env.example .env
# `.env` git'e gönderilmez; `.env.example` ise commit'lenir ve dokümantasyon görevi görür.

# Google Maps Android SDK anahtarı (GCP Console > APIs & Services > Credentials)
GOOGLE_MAPS_API_KEY=your_google_maps_android_api_key
