import * as React from 'react';
import { Provider as PaperProvider } from 'react-native-paper';
import { View, ActivityIndicator } from 'react-native';
import * as Font from 'expo-font';
import RootNavigator from './navigation';
import { theme } from './theme/theme'; // Import the custom theme
import { useLocationTracking } from './hooks/useLocationTracking';
import { useNotifications } from './hooks/useNotifications';
import NotificationBanner from './components/NotificationBanner';
import GlobalNotification from './components/GlobalNotification';

// Main App component, the root of the application.
// Uygulamanın kökü olan ana App componenti.
export default function App() {
  const [fontsLoaded, setFontsLoaded] = React.useState(false);

  // Load fonts before rendering the app
  // Uygulamayı render etmeden önce fontları yükle
  React.useEffect(() => {
    async function loadFonts() {
      try {
        await Font.loadAsync({
          MaterialCommunityIcons: require('react-native-vector-icons/Fonts/MaterialCommunityIcons.ttf'),
        });
        setFontsLoaded(true);
      } catch (error) {
        console.error('Error loading fonts:', error);
        // Even if font loading fails, continue to show the app
        // Font yükleme başarısız olsa bile uygulamayı göster
        setFontsLoaded(true);
      }
    }
    loadFonts();
  }, []);

  // This hook is called here to ensure location tracking starts as soon as the app loads
  // and continues to run globally throughout the app's lifecycle.
  // Bu hook, uygulama yüklenir yüklenmez konum takibinin başlamasını ve uygulama yaşam döngüsü boyunca
  // global olarak çalışmaya devam etmesini sağlamak için burada çağrılır.
  useLocationTracking();

  // Initialize push notifications
  // Push bildirimlerini başlat
  const { expoPushToken, notification, showBanner, setShowBanner } = useNotifications();

  // Log push token when available
  // Push token hazır olduğunda logla
  React.useEffect(() => {
    if (expoPushToken) {
      console.log('');
      console.log('╔════════════════════════════════════════╗');
      console.log('║       FCM TOKEN HAZIR!                ║');
      console.log('╚════════════════════════════════════════╝');
      console.log('🔔 Token:', expoPushToken);
      console.log('📋 Bu token\'ı Firebase Console\'da test et!');
      console.log('');
    }
  }, [expoPushToken]);

  // Log when notification received
  // Bildirim alındığında logla
  React.useEffect(() => {
    if (notification) {
      console.log('📬 New Notification:', notification.request.content);
    }
  }, [notification]);

  // Show loading indicator while fonts are loading
  // Fontlar yüklenirken loading göstergesi göster
  if (!fontsLoaded) {
    return (
      <View style={{ flex: 1, justifyContent: 'center', alignItems: 'center' }}>
        <ActivityIndicator size="large" color="#6200ee" />
      </View>
    );
  }

  return (
    // React Native Paper provider to apply the custom theme.
    // Özel temayı uygulamak için React Native Paper provider'ı.
    <PaperProvider theme={theme}>
      {/* The main navigator component that handles all screen transitions. */}
      {/* Tüm ekran geçişlerini yöneten ana navigator componenti. */}
      <RootNavigator />

      {/* In-app notification banner */}
      {/* Uygulama içi bildirim banner'ı */}
      <NotificationBanner
        visible={showBanner}
        title={notification?.request.content.title || ''}
        body={notification?.request.content.body || ''}
        onDismiss={() => setShowBanner(false)}
        onPress={() => {
          setShowBanner(false);
          // TODO: Navigate to notification detail or relevant screen
          console.log('Banner tıklandı:', notification?.request.content.data);
        }}
      />

      {/* Global notification for errors and success messages */}
      {/* Hata ve başarı mesajları için global bildirim */}
      <GlobalNotification />
    </PaperProvider>
  );
}
